<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    
    <link rel="stylesheet" href="/styles/style.css">
    <script defer src="/scripts/client.js"></script>
  </head>
  <body> 

    {% comment %} index.liquid {% endcomment %}
    {% if Home%}
        <header class="home-top-navbar">
          <h1>Home<h1>
        <header>
      
      {% comment %} groups.liquid {% endcomment %}
      {% elsif MultipleGroups %}
        <header class="groups-top-navbar">
          <h1>Your groups</h1>
          <button>
            <svg height="30" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
              <title>Add group</title>
              <path id="Shape" fill-rule="evenodd" clip-rule="evenodd" d="M36 20.5714H20.5714V36H15.4286V20.5714H0V15.4286H15.4286V0H20.5714V15.4286H36V20.5714V20.5714Z" fill=""/>
            </svg>
          </button>
        </header>

      {% comment %} one-group.liquid {% endcomment %}
      {% elsif OneGroup %}
        <header class="one-group-top-navbar">
          <a href="/groups">
            <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" height="30">
              <title>Go back to your groups</title>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M7.6 14L18.8 2.8L16 0L0 16L16 32L18.8 29.2L7.6 18H32V14H7.6Z" fill=""/>
            </svg>
          </a>
          <h1>{{ OneSnappMap.name }}</h1>
          <button>
            <svg height="30" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
              <title>Add Snappmap</title>
              <path id="Shape" fill-rule="evenodd" clip-rule="evenodd" d="M36 20.5714H20.5714V36H15.4286V20.5714H0V15.4286H15.4286V0H20.5714V15.4286H36V20.5714V20.5714Z" fill=""/>
            </svg>
          </button>
        </header>

      {% comment %} snappmaps.liquid {% endcomment %}
      {% elsif MultipleSnappMapslist %}
        <header class="snappmaps-top-navbar">
          <h1>Snappmaps</h1>
          <button>
            <svg height="30" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
              <title>Add Snappmap</title>
              <path id="Shape" fill-rule="evenodd" clip-rule="evenodd" d="M36 20.5714H20.5714V36H15.4286V20.5714H0V15.4286H15.4286V0H20.5714V15.4286H36V20.5714V20.5714Z" fill=""/>
            </svg>
          </button>
        </header>
      
      {% comment %} one-snappmap.liquid {% endcomment %}
      {% elsif OneSnappMap %}
        <header class="one-snappmap-top-navbar">
          {% comment %} Make variable of the header name {% endcomment %}
          {% assign headerName = OneSnappMappInfo.name %}
          
          <details class="header-collapsible-list">
            <summary><h1>{{OneSnappMappInfo.name}}</h1></summary>

            {% comment %} List of names of other snappmaps in the same group {% endcomment %}
            {% for groups in OneSnappMappInfo.groups %}
              {% for snappmap in groups.snappthis_group_uuid.snappmap %}
                {% comment %} Make variable of other snappmap names {% endcomment %}
                {% assign listName = snappmap.snappthis_snapmap_uuid.name %}

                {% comment %} Check if a name of other snappmap is not the same as the header name, if it's not than show the name {% endcomment %}
                {% if snappmap.snappthis_snapmap_uuid.name != headerName %}
                  <ul>
                    <li><a href="/snappmaps/{{ snappmap.snappthis_snapmap_uuid.name }}">{{ snappmap.snappthis_snapmap_uuid.name }}</a></li>
                  </ul> 
                {% endif %}
              {% endfor %}
            {% endfor %}
          </details>
          
          <button>
            <svg viewBox="0 0 37 37" xmlns="http://www.w3.org/2000/svg" height="30">
              <title>Change gridsize</title>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M0.894775 9.40015H9.89478V0.400146H0.894775V9.40015V9.40015ZM14.3948 36.4001H23.3948V27.4001H14.3948V36.4001V36.4001ZM0.894775 36.4001H9.89478V27.4001H0.894775V36.4001V36.4001ZM0.894775 22.9001H9.89478V13.9001H0.894775V22.9001V22.9001ZM14.3948 22.9001H23.3948V13.9001H14.3948V22.9001V22.9001ZM27.8948 0.400146V9.40015H36.8948V0.400146H27.8948V0.400146ZM14.3948 9.40015H23.3948V0.400146H14.3948V9.40015V9.40015ZM27.8948 22.9001H36.8948V13.9001H27.8948V22.9001V22.9001ZM27.8948 36.4001H36.8948V27.4001H27.8948V36.4001V36.4001Z" fill=""/>
            </svg>
          </button>
        </header>
      
      {% comment %} snapps.liquid {% endcomment %}
      {% elsif path %}
        <header class="snapps-top-navbar">
          <h1>Snapps</h1>
        </header>
      {% elsif pathLocation %}
        <header class="snapps-top-navbar">
          {% for OneSnapp in MultipleSnapps limit: 1 %}
            <h1>{{ OneSnapp.location}}</h1>
          {% endfor %}
          
        </header>
    {% endif %}